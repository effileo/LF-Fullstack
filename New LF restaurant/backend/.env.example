# Your Neon PostgreSQL connection string (from https://console.neon.tech)
# Use the "pooled" connection string. Add connect_timeout=15 if you see P1001 (cold start).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&connect_timeout=15"
PORT=5000
JWT_SECRET="your_super_secret_jwt_key_should_be_long_and_random"
